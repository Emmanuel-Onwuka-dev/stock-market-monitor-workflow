      "parameters": {
        "promptType": "define",
        "text": "=You are a financial market analyst. Below is scraped data from Yahoo Finance markets page.\n\nAnalyze the content and categorize market performance into three sections labeled exactly as shown:\n\nUP:\n- [Stock/Index] — [performance and reason]\n\nDOWN:\n- [Stock/Index] — [performance and reason]\n\nSTABLE:\n- [Stock/Index] — [performance and reason]\n\nHere is the content:\n{{ $json.data.markdown }}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -512,
        -80
      ],
      "id": "d9d4286f-03f0-42f9-994e-84f5d8af4415",
      "name": "classify the scraped stocks into up, down and stable",
      "notesInFlow": true,
      "notes": "categorizes the stock market text into up, down, and stable"
    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.text;\n\nconst upMatch = text.match(/UP:([\\s\\S]*?)DOWN:/);\nconst downMatch = text.match(/DOWN:([\\s\\S]*?)STABLE:/);\nconst stableMatch = text.match(/STABLE:([\\s\\S]*?)$/);\n\nconst clean = (str) => str ? str.replace(/\\*\\*/g, '').replace(/\\\\\\n/g, '\\n').trim() : '';\n\nconst up = clean(upMatch ? upMatch[1] : '');\nconst down = clean(downMatch ? downMatch[1] : '');\nconst stable = clean(stableMatch ? stableMatch[1] : '');\n\nreturn [{ json: { up, down, stable } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        368,
        -96
      ],
      "id": "173e0655-6853-4a8d-9b5c-1de71503bc98",
      "name": "standardized the text to make it readable for consumers"
    },
