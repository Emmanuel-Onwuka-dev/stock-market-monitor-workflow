    {
      "parameters": {
        "jsCode": "// Self-healing retry logic using static data (persists across loop iterations)\nconst MAX_RETRIES = 3;\n\nconst workflowStaticData = $getWorkflowStaticData('global');\n\nlet retryCount = workflowStaticData.retryCount ?? 0;\n\nif (retryCount >= MAX_RETRIES) {\n  // Reset counter for next day's run before bailing out\n  workflowStaticData.retryCount = 0;\n\n  return [\n    {\n      json: {\n        status: \"FAILED\",\n        message: `Firecrawl returned empty data after ${MAX_RETRIES} attempts. Manual check needed.`,\n        retryCount,\n        timestamp: new Date().toISOString(),\n      },\n    },\n  ];\n}\n\n// Increment and persist the count\nworkflowStaticData.retryCount = retryCount + 1;\n\nreturn [\n  {\n    json: {\n      retryCount: workflowStaticData.retryCount,\n      status: \"RETRYING\",\n      message: `Attempt ${workflowStaticData.retryCount} of ${MAX_RETRIES} — re-triggering scrape...`,\n      timestamp: new Date().toISOString(),\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        112,
        160
      ],
      "id": "5b65b72f-252c-48d0-ab95-5a6c737ac52a",
      "name": "Self healing path node",
      "notesInFlow": true,
      "notes": "Creates a loop set for  3 times. If it still fails after the 3rd time, a message is sent"
    },
